# Google Calendar
GOOGLE_APPLICATION_CREDENTIALS=config/service-account.json
GOOGLE_CALENDAR_ID=primary

# WhatsApp (Exemplo)
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_API_KEY=sua_chave_whatsapp
